dist/
client/dist/
server/dist/
*.tsbuildinfo

# Local environment
.env
.env.*
!.env.example

# Logs and temporary runtime files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.dev-server.*.log
.mobile-check-dev.log
