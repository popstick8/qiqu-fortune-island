# Local audio library
# Keep music, sound effects, lyrics, and the generated manifest on this machine.
# Public clones fall back to the built-in synthesized audio until the user adds
# audio files they are licensed to use.
client/public/audio/bgm/*
!client/public/audio/bgm/.gitkeep
client/public/audio/sfx/*
!client/public/audio/sfx/.gitkeep
client/public/audio/manifest.json

# OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
